# =========================================================
# MEI no Limite — variáveis de ambiente (MODELO)
# =========================================================
# IMPORTANTE: em PRODUÇÃO, configure estas variáveis APENAS no
# painel da Vercel (Settings -> Environment Variables).
#
# Este arquivo é um MODELO e é versionado pelo git — NUNCA coloque
# valores reais aqui. Para rodar localmente, copie para ".env.local"
# (que é ignorado pelo git) e preencha lá.
# NÃO use ".env.local.txt" — o Next não lê esse nome.
# =========================================================

# Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Service role key (SECRETA — nunca exponha no front-end).
# Usada só no servidor: criação de conta no cadastro e relatório público.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta
