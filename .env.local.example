# =========================================================
# MEI no Limite — variáveis de ambiente (MODELO)
# =========================================================
# IMPORTANTE: em PRODUÇÃO, configure estas variáveis APENAS no
# painel da Vercel (Settings -> Environment Variables).
#
# Este arquivo é um MODELO e é versionado pelo git — NUNCA coloque
# valores reais aqui. Para rodar localmente, copie para ".env.local"
# (que é ignorado pelo git) e preencha lá.
# NÃO use ".env.local.txt" — o Next não lê esse nome.
# =========================================================

# Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Service role key (SECRETA — nunca exponha no front-end).
# Usada só no servidor: criação de conta no cadastro e relatório público.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# Cakto — webhook de pagamento. Use o MESMO valor configurado no painel
# da Cakto. Em produção, defina na Vercel -> Environment Variables.
# (NÃO coloque o valor real aqui — este arquivo é versionado.)
CAKTO_WEBHOOK_SECRET=defina-na-vercel

# Link público de checkout da Cakto (botão "Assinar agora" em /assinar).
NEXT_PUBLIC_CAKTO_CHECKOUT_URL=https://pay.cakto.com.br/SEU-PRODUTO

# Resend — e-mail transacional (boas-vindas). https://resend.com -> API Keys.
# RESEND_FROM exige um DOMÍNIO VERIFICADO no Resend.
RESEND_API_KEY=re_sua_chave_resend
RESEND_FROM=MEI no Limite <nao-responda@meinolimite.com.br>

# URL pública do app (links nos e-mails). Opcional — default: produção.
NEXT_PUBLIC_APP_URL=https://www.meinolimite.com.br
